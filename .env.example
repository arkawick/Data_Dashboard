# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/
DB_NAME=test_db

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-with-a-real-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1

# ── FastAPI / GraphRAG ────────────────────────────────────────────────────────
FASTAPI_URL=http://localhost:8001

# ── LLM backends (set one to enable live answers) ────────────────────────────
ANTHROPIC_API_KEY=
OLLAMA_MODEL=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-real-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_HOURS=8
JWT_REFRESH_EXPIRE_DAYS=7
