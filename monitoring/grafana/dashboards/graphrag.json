{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.3.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "GraphRAG Data Dashboard - API & pipeline monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Chunks Loaded",
      "type": "stat",
      "targets": [{ "expr": "graphrag_chunks_loaded", "legendFormat": "Chunks" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Graph Nodes",
      "type": "stat",
      "targets": [{ "expr": "graphrag_graph_nodes_total", "legendFormat": "Nodes" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Graph Edges",
      "type": "stat",
      "targets": [{ "expr": "graphrag_graph_edges_total", "legendFormat": "Edges" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 4,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "FastAPI Request Rate by Backend",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(graphrag_requests_total[5m])", "legendFormat": "{{endpoint}} / {{backend}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "FastAPI Request Latency (P95)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(graphrag_request_seconds_bucket[5m]))", "legendFormat": "p95 {{endpoint}}" },
        { "expr": "histogram_quantile(0.50, rate(graphrag_request_seconds_bucket[5m]))", "legendFormat": "p50 {{endpoint}}" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Django Request Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(django_requests_total[5m])", "legendFormat": "{{method}} {{view}} ({{status_code}})" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Django Request Latency (P95)",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(django_request_seconds_bucket[5m]))", "legendFormat": "p95 {{view}}" }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["graphrag", "dashboard"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "title": "GraphRAG Dashboard",
  "uid": "graphrag-main",
  "version": 1
}
